<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.campusconnect.view.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.campusconnect.view.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordSelectionFragment"
            app:destination="@id/forgotPasswordSelectionFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.campusconnect.view.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action android:id="@+id/action_homeFragment_to_skillsFragment" app:destination="@id/skillsFragment" />
        <action android:id="@+id/action_homeFragment_to_startupFragment" app:destination="@id/startupFragment" />
        <action android:id="@+id/action_homeFragment_to_eventsFragment" app:destination="@id/eventsFragment" />
        <action android:id="@+id/action_homeFragment_to_profileFragment" app:destination="@id/profileFragment" />
        <action android:id="@+id/action_homeFragment_to_notificationsFragment" app:destination="@id/notificationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/skillsFragment"
        android:name="com.example.campusconnect.view.SkillsFragment"
        android:label="Skills"
        tools:layout="@layout/fragment_skills">
        <action android:id="@+id/action_skillsFragment_to_profileFragment" app:destination="@id/profileFragment" />
        <action android:id="@+id/action_skillsFragment_to_publicProfileFragment" app:destination="@id/publicProfileFragment" />
        <action android:id="@+id/action_skillsFragment_to_chatFragment" app:destination="@id/chatFragment" />
        <action android:id="@+id/action_skillsFragment_to_loginFragment" app:destination="@id/loginFragment" />
        <action android:id="@+id/action_skillsFragment_to_notificationsFragment" app:destination="@id/notificationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/publicProfileFragment"
        android:name="com.example.campusconnect.view.PublicProfileFragment"
        android:label="Public Profile"
        tools:layout="@layout/fragment_public_profile">
        <argument
            android:name="userId"
            app:argType="string" />
        <action android:id="@+id/action_publicProfileFragment_to_chatFragment" app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/startupFragment"
        android:name="com.example.campusconnect.view.StartUpFragment"
        android:label="StartUp Hub"
        tools:layout="@layout/fragment_startup">
        <action android:id="@+id/action_startupFragment_to_startupDetailsFragment" app:destination="@id/startupDetailsFragment" />
        <action android:id="@+id/action_startupFragment_to_postStartupFragment" app:destination="@id/postStartupFragment" />
    </fragment>

    <fragment
        android:id="@+id/postStartupFragment"
        android:name="com.example.campusconnect.view.PostStartupFragment"
        android:label="Post Idea"
        tools:layout="@layout/fragment_post_startup" />

    <fragment
        android:id="@+id/startupDetailsFragment"
        android:name="com.example.campusconnect.view.StartUpDetailsFragment"
        android:label="StartUp Details"
        tools:layout="@layout/fragment_startup_details" />

    <fragment
        android:id="@+id/eventsFragment"
        android:name="com.example.campusconnect.view.EventsFragment"
        android:label="Events"
        tools:layout="@layout/fragment_events">
        <action
            android:id="@+id/action_eventsFragment_to_eventDetailsFragment"
            app:destination="@id/eventDetailsFragment" />
        <action
            android:id="@+id/action_eventsFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment" />
        <action
            android:id="@+id/action_eventsFragment_to_eventRegistrationFragment"
            app:destination="@id/eventRegistrationFragment" />
    </fragment>

    <fragment
        android:id="@+id/eventDetailsFragment"
        android:name="com.example.campusconnect.view.EventDetailsFragment"
        android:label="Event Details"
        tools:layout="@layout/fragment_event_details">
        <argument
            android:name="event"
            app:argType="com.example.campusconnect.model.Event" />
        <action
            android:id="@+id/action_eventDetailsFragment_to_eventRegistrationFragment"
            app:destination="@id/eventRegistrationFragment" />
        <action
            android:id="@+id/action_eventDetailsFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/eventRegistrationFragment"
        android:name="com.example.campusconnect.view.EventRegistrationFragment"
        android:label="Event Registration"
        tools:layout="@layout/fragment_event_registration">
        <argument
            android:name="event"
            app:argType="com.example.campusconnect.model.Event" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.campusconnect.view.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <argument
            android:name="userId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <action android:id="@+id/action_profileFragment_to_loginFragment" app:destination="@id/loginFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true"/>
        <action android:id="@+id/action_profileFragment_to_aboutUsFragment" app:destination="@id/aboutUsFragment" />
        <action android:id="@+id/action_profileFragment_to_chatListFragment" app:destination="@id/chatListFragment" />
        <action android:id="@+id/action_profileFragment_to_editProfileFragment" app:destination="@id/editProfileFragment" />
        <action android:id="@+id/action_profileFragment_to_myEventsFragment" app:destination="@id/myEventsFragment" />
        <action android:id="@+id/action_profileFragment_to_myStartupsFragment" app:destination="@id/myStartupsFragment" />
        <action android:id="@+id/action_profileFragment_to_resumeBuilderFragment" app:destination="@id/resumeBuilderFragment" />
        <action android:id="@+id/action_profileFragment_to_settingsFragment" app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.campusconnect.view.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action android:id="@+id/action_settingsFragment_to_aboutUsFragment" app:destination="@id/aboutUsFragment" />
        <action android:id="@+id/action_settingsFragment_to_forgotPasswordSelectionFragment" app:destination="@id/forgotPasswordSelectionFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_changePasswordFragment"
            app:destination="@id/changePasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.example.campusconnect.view.ChangePasswordFragment"
        android:label="Change Password"
        tools:layout="@layout/fragment_change_password" />

    <fragment
        android:id="@+id/resumeBuilderFragment"
        android:name="com.example.campusconnect.view.ResumeBuilderFragment"
        android:label="Resume Builder"
        tools:layout="@layout/fragment_resume_builder" />

    <fragment
        android:id="@+id/myEventsFragment"
        android:name="com.example.campusconnect.view.MyEventsFragment"
        android:label="My Events"
        tools:layout="@layout/fragment_my_events" />

    <fragment
        android:id="@+id/myStartupsFragment"
        android:name="com.example.campusconnect.view.MyStartupsFragment"
        android:label="My Startups"
        tools:layout="@layout/fragment_my_startups" />

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.campusconnect.view.EditProfileFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_edit_profile" />

    <fragment
        android:id="@+id/aboutUsFragment"
        android:name="com.example.campusconnect.view.AboutUsFragment"
        android:label="About Us"
        tools:layout="@layout/fragment_about_us" />

    <fragment
        android:id="@+id/chatListFragment"
        android:name="com.example.campusconnect.view.ChatListFragment"
        android:label="Chats"
        tools:layout="@layout/fragment_chat_list">
        <action
            android:id="@+id/action_chatListFragment_to_userListFragment"
            app:destination="@id/userListFragment" />
        <action
            android:id="@+id/action_chatListFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/userListFragment"
        android:name="com.example.campusconnect.view.UserListFragment"
        android:label="Select User"
        tools:layout="@layout/fragment_user_list">
        <action
            android:id="@+id/action_userListFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.campusconnect.view.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat">
        <action
            android:id="@+id/action_chatFragment_to_callFragment"
            app:destination="@id/callFragment" />
    </fragment>

    <fragment
        android:id="@+id/callFragment"
        android:name="com.example.campusconnect.view.CallFragment"
        android:label="Call"
        tools:layout="@layout/fragment_call">
        <argument
            android:name="userId"
            app:argType="string" />
        <argument
            android:name="callId"
            app:argType="string"
            app:nullable="true" />
        <argument
            android:name="isIncoming"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <!-- Forgot Password Flow Fragments -->
    <fragment
        android:id="@+id/forgotPasswordSelectionFragment"
        android:name="com.example.campusconnect.view.ForgotPasswordSelectionFragment"
        android:label="Reset Options"
        tools:layout="@layout/fragment_forgot_password_selection">
        <action
            android:id="@+id/action_forgotPasswordSelectionFragment_to_otpVerificationFragment"
            app:destination="@id/otpVerificationFragment" />
    </fragment>

    <fragment
        android:id="@+id/otpVerificationFragment"
        android:name="com.example.campusconnect.view.OtpVerificationFragment"
        android:label="Verify OTP"
        tools:layout="@layout/fragment_otp_verification">
        <argument
            android:name="phoneNumber"
            app:argType="string"
            app:nullable="true" />
        <action
            android:id="@+id/action_otpVerificationFragment_to_resetPasswordFragment"
            app:destination="@id/resetPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.example.campusconnect.view.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.example.campusconnect.view.ResetPasswordFragment"
        android:label="New Password" />

</navigation>
