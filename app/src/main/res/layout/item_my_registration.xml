<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_white_rounded_card"
    android:elevation="2dp"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_stats_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:text="Category"
        android:textColor="#C1272D"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvEventType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EVENT TYPE"
        android:textColor="#94A3B8"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvCategory"
        app:layout_constraintBottom_toBottomOf="@id/tvCategory" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Event Title"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvCategory" />

    <TextView
        android:id="@+id/tvVenue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Venue: RKU Campus"
        android:textColor="#6B7280"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date: Jan 01, 2026"
        android:textColor="#6B7280"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvVenue" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAction"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#F1F5F9"
        android:text="Entry Pass"
        android:textAllCaps="false"
        android:textColor="#1F2937"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:icon="@drawable/copy"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="#1F2937"
        app:layout_constraintTop_toBottomOf="@id/tvDate" />

</androidx.constraintlayout.widget.ConstraintLayout>
