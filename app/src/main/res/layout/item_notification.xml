<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_white_rounded_card"
    android:elevation="2dp"
    android:padding="16dp">

    <FrameLayout
        android:id="@+id/cvIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_white_rounded_card"
        android:backgroundTint="#FFF1F1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/ivNotificationIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/skills"
            app:tint="#C1272D"
            android:contentDescription="Notification Icon" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvNotificationTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:text="New Skill Request"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/viewUnreadDot"
        app:layout_constraintStart_toEndOf="@id/cvIcon"
        app:layout_constraintTop_toTopOf="@id/cvIcon" />

    <View
        android:id="@+id/viewUnreadDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_notification_dot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvNotificationTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvNotificationTitle" />

    <TextView
        android:id="@+id/tvNotificationBody"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Arjun Mehta wants to learn UI/UX from you."
        android:textColor="#4B5563"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvNotificationTitle"
        app:layout_constraintTop_toBottomOf="@id/tvNotificationTitle" />

    <TextView
        android:id="@+id/tvNotificationTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="2m ago"
        android:textColor="#9CA3AF"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/tvNotificationTitle"
        app:layout_constraintTop_toBottomOf="@id/tvNotificationBody" />

</androidx.constraintlayout.widget.ConstraintLayout>
