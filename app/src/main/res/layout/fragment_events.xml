<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB"
    tools:context=".view.EventsFragment">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivUserHeaderImage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="fitCenter"
            android:src="@drawable/rkulogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="RKU Logo" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/ivUserHeaderImage"
            app:layout_constraintStart_toEndOf="@id/ivUserHeaderImage"
            app:layout_constraintTop_toTopOf="@id/ivUserHeaderImage">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome,"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/profile_circle"
            android:backgroundTint="@android:color/white"
            android:elevation="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnNotifications"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/search"
                app:tint="#000000"
                android:contentDescription="Search" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnNotifications"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/profile_circle"
            android:backgroundTint="@android:color/white"
            android:elevation="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                app:tint="#000000"
                android:contentDescription="Notifications" />
            <View
                android:id="@+id/viewNotificationBadge"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_red" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Campus Events"
                android:textColor="#000000"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Category Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/llCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/catAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_category_selected"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="All"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/catUpcoming"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category_item"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Upcoming"
                        android:textColor="#4B5563" />
                    <LinearLayout
                        android:id="@+id/catLive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category_item"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Now"
                            android:textColor="#4B5563" />
                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_notification_dot" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/catTechnical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category_item"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Technical"
                        android:textColor="#4B5563" />
                    <TextView
                        android:id="@+id/catCultural"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_category_item"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Cultural"
                        android:textColor="#4B5563" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Featured Event Carousel -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpFeaturedEvents"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginHorizontal="16dp"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tlIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@android:color/transparent"
                    app:layout_constraintBottom_toBottomOf="@id/vpFeaturedEvents"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tabBackground="@drawable/dot_selector"
                    app:tabIndicatorHeight="0dp"
                    app:tabRippleColor="@null" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Quick Action Icons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_white_rounded_card" android:backgroundTint="#FEE2E2">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/copy" app:tint="#C1272D" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvRegistrationCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="My Registrations\n00 Events"
                        android:textColor="#4B5563"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_white_rounded_card" android:backgroundTint="#DBEAFE">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/menu" app:tint="#3B82F6" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvPollStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Polls &amp; Interests\nActive Polls"
                        android:textColor="#4B5563"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_white_rounded_card" android:backgroundTint="#F3E8FF">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/event" app:tint="#A855F7" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvCalendarLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Event Calendar\nView Calendar"
                        android:textColor="#4B5563"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_white_rounded_card" android:backgroundTint="#FEF3C7">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_notification" app:tint="#F59E0B" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvReminderCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Reminders\n00 Upcoming"
                        android:textColor="#4B5563"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <FrameLayout android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_white_rounded_card" android:backgroundTint="#D1FAE5">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/star" app:tint="#10B981" />
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvCertificateCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Certificates\n00 Earned"
                        android:textColor="#4B5563"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Poll Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_white_rounded_card"
                android:backgroundTint="#FFF1F1"
                android:padding="20dp">
                <TextView
                    android:id="@+id/tvPollTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Help Us Plan Better Events!"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/btnViewAllPolls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All Polls >"
                    android:textColor="#C1272D"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/tvPollQuestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Which event would you like to see next?"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvPollTitle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tvPollQuestion">
                    <FrameLayout
                        android:id="@+id/cvPollOption1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_white_rounded_card"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                                <TextView android:id="@+id/tvPollOption1Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Option 1" android:textColor="#C1272D" android:textStyle="bold" android:textSize="12sp" />
                                <ImageView android:id="@+id/ivPollOption1Check" android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:src="@drawable/ic_check_circle" app:tint="#C1272D" android:visibility="gone" />
                            </RelativeLayout>
                            <TextView android:id="@+id/tvPollOption1Stats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="0% (0 votes)" android:textColor="#4B5563" android:textSize="11sp" />
                            <ProgressBar android:id="@+id/pbPollOption1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="8dp" android:progress="0" android:progressTint="#C1272D" />
                        </LinearLayout>
                    </FrameLayout>
                    <FrameLayout
                        android:id="@+id/cvPollOption2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_white_rounded_card"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                                <TextView android:id="@+id/tvPollOption2Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Option 2" android:textColor="#1F2937" android:textStyle="bold" android:textSize="12sp" />
                                <ImageView android:id="@+id/ivPollOption2Check" android:layout_width="16dp" android:layout_height="16dp" android:layout_alignParentEnd="true" android:src="@drawable/ic_check_circle" app:tint="#C1272D" android:visibility="gone" />
                            </RelativeLayout>
                            <TextView android:id="@+id/tvPollOption2Stats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="0% (0 votes)" android:textColor="#4B5563" android:textSize="11sp" />
                            <ProgressBar android:id="@+id/pbPollOption2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="8dp" android:progress="0" android:progressTint="#94A3B8" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Upcoming Events Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upcoming Events"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/btnSeeAllUpcoming"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="View All >"
                    android:textColor="#C1272D"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false" />

            <!-- My Registered Events Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Registered Events"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/btnSeeAllRegistered"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="View All >"
                    android:textColor="#C1272D"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Tab Filters -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_category_item"
                android:orientation="horizontal"
                android:padding="2dp">
                <TextView
                    android:id="@+id/tabUpcoming"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_category_selected"
                    android:gravity="center"
                    android:text="Upcoming (0)"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tabLive"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Live (0)"
                    android:textColor="#4B5563"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tabPast"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Past (0)"
                    android:textColor="#4B5563"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyRegisteredEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false" />

            <!-- Search Bar Container -->
            <LinearLayout
                android:id="@+id/cvSearch"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:background="@drawable/bg_white_rounded_card"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/search"
                    app:tint="#6B7280"
                    android:contentDescription="Search Icon" />

                <EditText
                    android:id="@+id/etSearchEvents"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="Search events...."
                    android:inputType="text"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hidden elements for code compatibility -->
    <FrameLayout android:id="@+id/cvLogo" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
