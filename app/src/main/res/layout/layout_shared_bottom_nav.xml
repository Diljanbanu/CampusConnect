<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sharedBottomNavCard"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:layout_gravity="bottom"
    android:background="@android:color/white"
    android:elevation="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/home"
                app:tint="@color/gray_text"
                android:contentDescription="Home" />
            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/gray_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Skills -->
        <LinearLayout
            android:id="@+id/btnNavSkills"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivNavSkills"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/skills"
                app:tint="@color/gray_text"
                android:contentDescription="Skills" />
            <TextView
                android:id="@+id/tvNavSkills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skills"
                android:textColor="@color/gray_text"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- StartUp -->
        <LinearLayout
            android:id="@+id/btnNavStartup"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivNavStartup"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/rocket_launch"
                app:tint="@color/gray_text"
                android:contentDescription="StartUp" />
            <TextView
                android:id="@+id/tvNavStartup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="StartUp"
                android:textColor="@color/gray_text"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Events -->
        <LinearLayout
            android:id="@+id/btnNavEvents"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivNavEvents"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/event"
                app:tint="@color/gray_text"
                android:contentDescription="Events" />
            <TextView
                android:id="@+id/tvNavEvents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Events"
                android:textColor="@color/gray_text"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/profile_circle"
                app:tint="@color/gray_text"
                android:contentDescription="Profile" />
            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@color/gray_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
