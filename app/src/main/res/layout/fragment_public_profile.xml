<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header -->
            <RelativeLayout
                android:id="@+id/rlHeader"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/back_arrow"
                    app:tint="#000000"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="24dp"
                    android:layout_toEndOf="@id/btnBack"
                    android:text="Profile"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/btnHeaderChat"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/chat"
                        app:tint="#C1272D"
                        android:contentDescription="Chat" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="16dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="#4A5568"
                        android:contentDescription="Call" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="16dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#4A5568"
                        android:contentDescription="Video" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Top Profile Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clTopInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/rlHeader">

                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_marginStart="-60dp"
                    android:layout_marginTop="-60dp"
                    android:background="@drawable/bg_circle_red_light"
                    android:backgroundTint="#FFF1F1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <FrameLayout
                    android:id="@+id/flImage"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#FFFFFF"
                        app:strokeWidth="4dp">
                        <ImageView
                            android:id="@+id/ivPublicProfileImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_profile_placeholder"
                            android:contentDescription="Profile Photo" />
                    </com.google.android.material.card.MaterialCardView>

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="10dp"
                        android:background="@drawable/bg_circle_red"
                        android:backgroundTint="#4CAF50" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/flImage"
                    app:layout_constraintTop_toTopOf="@id/flImage">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvPublicName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Name"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/copy"
                            app:tint="#C1272D"
                            android:contentDescription="Verified" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPublicRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_category_item"
                        android:backgroundTint="#FFF1F1"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="Software Developer"
                        android:textColor="#C1272D"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/mail" app:tint="#6B7280" android:contentDescription="Email" />
                            <TextView android:id="@+id/tvPublicEmail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="email@rku.ac.in" android:textColor="#4B5563" android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/menu" app:tint="#6B7280" android:contentDescription="Dept" />
                            <TextView android:id="@+id/tvPublicDept" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Computer Engineering" android:textColor="#4B5563" android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/home" app:tint="#6B7280" android:contentDescription="Location" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="RK University, Rajkot" android:textColor="#4B5563" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/llPublicStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_white_rounded_card"
                android:orientation="horizontal"
                android:paddingVertical="16dp"
                android:baselineAligned="false"
                app:layout_constraintTop_toBottomOf="@id/clTopInfo">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatSkills" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#C1272D" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Skills" android:textColor="#6B7280" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatProjects" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#C1272D" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Projects" android:textColor="#6B7280" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatConnections" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#C1272D" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connections" android:textColor="#6B7280" android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvStatCertificates" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#C1272D" android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Certificates" android:textColor="#6B7280" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- About Me -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_white_rounded_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/llPublicStats">

                <TextView
                    android:id="@+id/tvAboutTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About Me"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvPublicBio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="80dp"
                    android:lineSpacingExtra="4dp"
                    android:text="No bio provided yet."
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAboutTitle" />

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/rocket"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:contentDescription="Illustration" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Skills Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clSkills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_white_rounded_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/clAbout">

                <TextView
                    android:id="@+id/tvSkillsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skills"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All >"
                    android:textColor="#C1272D"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/publicSkillChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:chipSpacingHorizontal="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tvSkillsTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Projects Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clProjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_white_rounded_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/clSkills">

                <TextView
                    android:id="@+id/tvProjectsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Projects"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All >"
                    android:textColor="#C1272D"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#F8FAFC"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toBottomOf="@id/tvProjectsTitle">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="#3B82F6"
                            app:cardCornerRadius="8dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@drawable/home" app:tint="#FFFFFF" android:contentDescription="Proj" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvProjName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loading projects..." android:textColor="#000000" android:textStyle="bold" />
                            <TextView android:id="@+id/tvProjDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Project details will appear here." android:textColor="#64748B" android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Bottom Action Bar -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardElevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@android:color/white"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMessage"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Message"
                android:textAllCaps="false"
                android:textColor="#C1272D"
                app:cornerRadius="12dp"
                app:icon="@drawable/chat"
                app:iconPadding="8dp"
                app:iconTint="#C1272D"
                app:strokeColor="#C1272D" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#C1272D"
                android:text="Connect"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>