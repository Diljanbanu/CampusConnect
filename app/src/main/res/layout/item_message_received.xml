<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <FrameLayout
        android:id="@+id/cvUserImage"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/profile_circle"
        android:backgroundTint="#FFEAEA"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/ivUserImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile_placeholder"
            android:background="@drawable/profile_circle"
            android:clipToOutline="true"
            android:contentDescription="User" />

        <TextView
            android:id="@+id/tvUserInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="U"
            android:textColor="#C1272D"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvForwardedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="2dp"
        android:text="Forwarded"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        android:textStyle="italic"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/cvUserImage"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_received_message"
        android:maxWidth="260dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="Received message content"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/cvUserImage"
        app:layout_constraintTop_toBottomOf="@id/tvForwardedLabel" />

    <FrameLayout
        android:id="@+id/cardImage"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        android:background="@drawable/bg_received_message"
        android:padding="4dp"
        app:layout_constraintStart_toEndOf="@id/cvUserImage"
        app:layout_constraintTop_toBottomOf="@id/tvForwardedLabel">
        <ImageView
            android:id="@+id/ivImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:background="@drawable/bg_white_rounded_card"
            android:contentDescription="Received Image" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/llFileContainer"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_received_message"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/cvUserImage"
        app:layout_constraintTop_toBottomOf="@id/tvForwardedLabel">
        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/copy" app:tint="#C1272D" android:contentDescription="File" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
            <TextView android:id="@+id/tvFileName" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="file.pdf" android:textColor="#000000" android:textStyle="bold" android:textSize="12sp" android:ellipsize="middle" android:maxLines="1" />
            <TextView android:id="@+id/tvFileSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2.4 MB" android:textColor="#64748B" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="10:30 AM"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@id/tvMessage"
        app:layout_constraintTop_toBottomOf="@id/tvMessage" />

</androidx.constraintlayout.widget.ConstraintLayout>
