<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvForwardedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="Forwarded"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        android:textStyle="italic"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_sent_message"
        android:maxWidth="260dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="Sent message content"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvForwardedLabel" />

    <FrameLayout
        android:id="@+id/cardImage"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        android:background="@drawable/bg_sent_message"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvForwardedLabel">
        <ImageView
            android:id="@+id/ivImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:background="@drawable/bg_white_rounded_card"
            android:contentDescription="Sent Image" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/llFileContainer"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_sent_message"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvForwardedLabel">
        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/copy" app:tint="@android:color/white" android:contentDescription="File" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
            <TextView android:id="@+id/tvFileName" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="file.pdf" android:textColor="@android:color/white" android:textStyle="bold" android:textSize="12sp" android:ellipsize="middle" android:maxLines="1" />
            <TextView android:id="@+id/tvFileSize" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="2.4 MB" android:textColor="#E5E7EB" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvMessage">

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:35 AM"
            android:textColor="#9CA3AF"
            android:textSize="10sp" />

        <ImageView
            android:id="@+id/ivMessageTicks"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/copy"
            app:tint="#3B82F6"
            android:contentDescription="Status" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSeenStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="seen"
        android:textColor="#9CA3AF"
        android:textSize="9sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llMeta" />

    <!-- Hidden compatibility view -->
    <FrameLayout android:id="@+id/cvUserImage" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
