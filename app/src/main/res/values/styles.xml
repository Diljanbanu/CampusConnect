<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Typography Style -->
    <style name="TextAppearance.CampusConnect.Roboto" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Standard Button Style -->
    <style name="Widget.CampusConnect.Button" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/button_height_standard</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CampusConnect.Button.Primary" parent="Widget.CampusConnect.Button">
        <item name="backgroundTint">@color/primaryRed</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.CampusConnect.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height_standard</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">#D1D5DB</item>
        <item name="android:textColor">#4B5563</item>
    </style>

    <!-- Standard Card Style -->
    <style name="Widget.CampusConnect.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeColor">#F3F4F6</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
    </style>

</resources>